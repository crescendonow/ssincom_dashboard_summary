# ฐานข้อมูลระบบ bill (Railway PostgreSQL) — schema ss_invoices / products
# host public (proxy.rlwy.net) จะถูกเติม sslmode=require อัตโนมัติใน app/database.py
DATABASE_URL=postgresql://user:password@host:5432/database_name

# บัญชี login เดียวสำหรับเข้า dashboard
APP_USER=admin
APP_PASS=change-me

# secret สำหรับเซ็น session cookie — production ให้สุ่มยาว
SESSION_SECRET=change-me-long-random-secret
